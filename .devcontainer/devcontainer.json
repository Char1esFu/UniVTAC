{
  "name": "UniVTAC (CUDA 12.6 / Isaac Sim 4.5)",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "USERNAME": "${localEnv:USER}",
      // UID/GID default to 1000 (standard for the first user on most Linux distros).
      // If your host UID differs, VS Code adjusts it automatically via updateRemoteUserUID.
      "USER_UID": "1000",
      "USER_GID": "1000"
    }
  },

  // GPU passthrough + relaxed confinement — the devcontainer equivalent of the
  // distrobox `--additional-flags`. Requires the host docker to have the
  // NVIDIA Container Toolkit CDI spec configured (it already works for distrobox).
  "runArgs": [
    "--device", "nvidia.com/gpu=all",
    "--security-opt", "seccomp=unconfined",
    "--security-opt", "apparmor=unconfined"
  ],

  "containerEnv": {
    "NVIDIA_VISIBLE_DEVICES": "all",
    "NVIDIA_DRIVER_CAPABILITIES": "all",
    "ACCEPT_EULA": "Y",
    "OMNI_KIT_ACCEPT_EULA": "YES",
    "DISPLAY": "${localEnv:DISPLAY}",
    "XAUTHORITY": "/tmp/.Xauthority"
  },

  // Keep the in-container path identical to the host path.
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/${localEnv:USER}/Projects/UniVTAC,type=bind",
  "workspaceFolder": "/home/${localEnv:USER}/Projects/UniVTAC",

  // Persist the heavy bits across container rebuilds:
  //   miniforge -> the conda base + UniVTAC env (tens of GB)
  //   deps      -> IsaacLab, curobo, vcpkg (editable installs point here)
  //   cache     -> pip / HuggingFace / Omniverse caches
  "mounts": [
    "source=univtac-miniforge,target=/home/${localEnv:USER}/miniforge3,type=volume",
    "source=univtac-deps,target=/home/${localEnv:USER}/deps,type=volume",
    "source=univtac-cache,target=/home/${localEnv:USER}/.cache,type=volume",
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind",
    "source=${localEnv:XAUTHORITY},target=/tmp/.Xauthority,type=bind,readonly"
  ],

  "remoteUser": "${localEnv:USER}",

  // Remap the container user's UID to match the host if they differ.
  "updateRemoteUserUID": true,

  // Run Claude Code (and Python tooling) *inside* the container, against the
  // container's filesystem. The Claude Code extension ships a native binary,
  // so no Node is needed.
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "ms-python.python"
      ],
      // Override host settings: packages are all pip-installed, so let VSCode
      // treat the conda env as a plain system env rather than trying to manage it.
      "settings": {
        "python-envs.defaultEnvManager": "ms-python.python:system",
        "python-envs.defaultPackageManager": "ms-python.python:pip",
        "python.analysis.extraPaths": [
          "${env:HOME}/deps/IsaacLab/source/isaaclab",
          "${workspaceFolder}/third_party/TacEx/source/tacex",
          "${workspaceFolder}/third_party/TacEx/source/tacex_assets",
          "${workspaceFolder}/third_party/TacEx/source/tacex_tasks",
          "${workspaceFolder}/third_party/TacEx/source/tacex_uipc"
        ]
      }
    }
  },

  // Named volumes are created root-owned; hand them to the user once. This is
  // the only thing run automatically — the heavy env build stays manual.
  "postCreateCommand": "sudo chown $USER:$USER $HOME/miniforge3 $HOME/deps $HOME/.cache && echo 'Container ready. Run:  bash .devcontainer/setup-univtac-env.sh'"
}
